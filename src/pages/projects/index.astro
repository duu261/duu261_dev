---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const projectsData = await getCollection('projects');
const projects = projectsData.sort((a, b) =>
  (a.data.order ?? 999) - (b.data.order ?? 999)
);
---

<Layout title="Projects">
  <section class="projects-section hud-grid-bg">
    <div class="projects-header">
      <div class="hero-tag">
        <span class="stripe"><span class="stripe-track"></span></span>
        <span>DUU261.INDEVS.IN - PROJECTS</span>
      </div>
      <h1 class="projects-title">Projects</h1>
      <p class="projects-tagline">Case studies, not repo links - problem, architecture, tradeoffs, and what I'd change.</p>
      <div class="projects-prompt">
        <span class="prompt">❯</span>
        <span class="cmd">ls ~/projects</span>
        <span class="result">- {projects.length} entries</span>
      </div>
    </div>

    <div class="projects-watermark">作品</div>

    <div class="projects-grid">
      {projects.map((project, idx) => {
        const number = String(idx + 1).padStart(2, '0');
        const roleDisplay = (project.data.role || '')
          .split(' ')
          .map(word => word.toUpperCase())
          .join('\n');

        const description = (project.body ?? '').trim().split('\n\n')[0];

        return (
          <article class:list={['project-card', { unit02: project.data.order === 2 }]}>
            <div class="card-number">
              <span class="number">{number}</span>
              {project.data.order === 2 && <span class="jp-tag">弐号機</span>}
              <span class="role">{roleDisplay}</span>
            </div>
            <div class="card-content">
              <a href={`/projects/${project.id}`} class="card-title">
                {project.data.title}
              </a>
              <p class="card-description">{description}</p>
            </div>
            <div class="card-footer">
              <div class="card-stack">
                {project.data.stack.map((tag: string) => (
                  <span class="stack-tag">{tag}</span>
                ))}
              </div>
              <a href={`/projects/${project.id}`} class="card-link">
                case study →
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</Layout>

<style>
.projects-section {
  position: relative;
  flex: 1;
  padding: 72px 72px 64px;
  overflow: hidden;
}

.projects-watermark {
  position: absolute;
  top: -30px;
  right: -20px;
  font-family: var(--font-heading-jp);
  font-weight: 800;
  font-size: 200px;
  line-height: 1;
  color: rgba(237, 135, 150, 0.09);
  user-select: none;
}

.projects-header {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.projects-title {
  margin: 0;
  font-family: var(--font-heading-jp);
  font-weight: 800;
  font-size: 72px;
  line-height: 1;
  color: var(--ctp-text);
}

.projects-tagline {
  margin: 0;
  font-family: var(--font-mono);
  font-size: 14px;
  line-height: 1.8;
  color: var(--ctp-subtext);
}

.projects-prompt {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-mono);
  font-size: 14px;
}

.projects-prompt .prompt {
  color: var(--ctp-red);
}

.projects-prompt .cmd {
  color: var(--ctp-green);
}

.projects-prompt .result {
  color: var(--ctp-muted);
}

.projects-grid {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-top: 52px;
}

.project-card {
  background: var(--ctp-mantle);
  border-left: 3px solid var(--ctp-red);
  padding: 28px 32px;
  display: grid;
  grid-template-columns: 90px 1fr 240px;
  gap: 28px;
  align-items: start;
  clip-path: polygon(0 0, calc(100% - 18px) 0, 100% 18px, 100% 100%, 0 100%);
  transition: transform 0.2s, background 0.2s;
}

.project-card:hover {
  background: var(--ctp-base);
  transform: translateY(-3px);
}

.project-card.unit02 { border-left-color: var(--ctp-peach); position: relative; }
.project-card.unit02::after {
  content: '02';
  position: absolute; right: 4px; bottom: -22px;
  font-family: var(--font-body); font-weight: 900; font-size: 130px; line-height: 1;
  color: transparent; -webkit-text-stroke: 1px rgba(245, 169, 127, 0.22);
  pointer-events: none;
}
.project-card.unit02 .number { color: var(--ctp-peach); }
.project-card.unit02:hover { box-shadow: 0 0 18px rgba(245, 169, 127, 0.18); }
.jp-tag {
  align-self: flex-start;
  padding: 1px 6px;
  font-size: 10px; letter-spacing: 2px;
  color: var(--ctp-peach); border: 1px solid rgba(245, 169, 127, 0.4);
}

.card-number {
  display: flex;
  flex-direction: column;
  gap: 8px;
  font-family: var(--font-mono);
}

.card-number .number {
  font-size: 26px;
  font-weight: 700;
  color: var(--ctp-red);
}

.card-number .role {
  font-size: 10px;
  letter-spacing: 2px;
  color: var(--ctp-muted);
  white-space: pre-line;
  line-height: 1.2;
}

.card-content {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.card-title {
  font-size: 22px;
  font-weight: 800;
  color: var(--ctp-text);
  cursor: pointer;
  transition: color 0.2s;
}

.card-title:hover {
  color: var(--ctp-peach);
}

.card-description {
  margin: 0;
  font-size: 14px;
  line-height: 1.7;
  color: var(--ctp-subtext);
}

.card-footer {
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: flex-end;
}

.card-stack {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.stack-tag {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ctp-peach);
  border: 1px solid rgba(245, 169, 127, 0.35);
  padding: 3px 8px;
}

.card-link {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--ctp-red);
  letter-spacing: 1px;
  transition: color 0.2s;
}

.card-link:hover {
  color: var(--ctp-peach);
}

/* Mobile responsive */
@media (max-width: 1080px) {
  .projects-section {
    padding: 56px 56px 48px;
  }

  .projects-title {
    font-size: 52px;
  }

  .project-card {
    grid-template-columns: 80px 1fr 180px;
    gap: 20px;
    padding: 20px 24px;
  }

  .card-number .number {
    font-size: 22px;
  }

  .card-title {
    font-size: 18px;
  }
}

@media (max-width: 760px) {
  .projects-section {
    padding: 40px 24px 32px;
  }

  .projects-watermark {
    font-size: 120px;
    top: -20px;
    right: -10px;
  }

  .projects-title {
    font-size: 40px;
  }

  .project-card {
    grid-template-columns: 1fr;
    gap: 16px;
    padding: 20px 16px;
  }

  .card-number {
    flex-direction: row;
    gap: 12px;
    align-items: baseline;
  }

  .card-footer {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }

  .card-stack {
    justify-content: flex-start;
  }

  .card-title {
    font-size: 16px;
  }

  .card-description {
    font-size: 13px;
  }
}
</style>
